{
  "name": "agent-summoner",
  "version": "0.1.0",
  "description": "Ambient multi-agent orchestration for pi — Scout, Crafter, Gatekeeper. Phase 1: core loop with heuristic triggers and RPC subprocesses.",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src/**/*.ts"
  ],
  "keywords": [
    "pi-extension",
    "agent",
    "orchestrator",
    "summoner"
  ],
  "license": "MIT",
  "author": "Zoych",
  "pi": {
    "extensions": ["./src"]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bawas07/pi-summoner"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit && node --import tsx --test src/**/*.test.ts",
    "test:watch": "node --import tsx --test --watch src/**/*.test.ts"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0"
  }
}
